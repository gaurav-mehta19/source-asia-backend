APP_ENV=development
HTTP_PORT=8080
HTTP_READ_TIMEOUT_SECONDS=10
HTTP_WRITE_TIMEOUT_SECONDS=10
HTTP_SHUTDOWN_TIMEOUT_SECONDS=15
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60
PRODUCT_MAX_URLS_PER_REQUEST=20
PRODUCT_MAX_URL_LENGTH=2048
PRODUCT_DEFAULT_PAGE_LIMIT=20
PRODUCT_MAX_PAGE_LIMIT=100
PRODUCT_MAX_MEDIA_PER_PRODUCT=200
LOG_LEVEL=info
